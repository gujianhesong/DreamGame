<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base AppCompat theme for regular activities -->
    <style name="Theme.DreamGame" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Fullscreen theme for game view (extends base theme) -->
    <style name="Theme.DreamGame.Game" parent="Theme.DreamGame">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
